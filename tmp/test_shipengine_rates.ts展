
import dotenv from 'dotenv';
import path from 'path';

dotenv.config({ path: path.join(process.cwd(), '.env') });

const apiKey = process.env.SHIPSTATION_API_KEY;

if (!apiKey) {
  console.error("SHIPSTATION_API_KEY not found in .env");
  process.exit(1);
}

async function testShipEngineRates() {
  console.log("\n--- Testing: ShipEngine V1 Rates API ---");
  try {
    const response = await fetch('https://api.shipengine.com/v1/rates', {
      method: 'POST',
      headers: { 
        'API-Key': apiKey,
        'Content-Type': 'application/json' 
      },
      body: JSON.stringify({
        shipment_details: {
          ship_from: {
            name: "FCAO",
            phone: "000-000-0000",
            address_line1: "123 Main St",
            city_locality: "Glendale",
            state_province: "CA",
            postal_code: "91205",
            country_code: "US"
          },
          ship_to: {
            name: "Customer",
            address_line1: "456 Customer Ave",
            city_locality: "Beverly Hills",
            state_province: "CA",
            postal_code: "90210",
            country_code: "US"
          },
          packages: [
            {
              weight: { value: 2, unit: "pound" },
              dimensions: { length: 12, width: 9, height: 3, unit: "inch" }
            }
          ]
        },
        rate_options: {
          carrier_ids: [] // Get all
        }
      })
    });

    console.log(`Status: ${response.status} ${response.statusText}`);
    if (response.ok) {
      console.log("✅ SUCCESS! This is a ShipEngine key.");
      const data = await response.json();
      console.log(JSON.stringify(data, null, 2));
    } else {
      const text = await response.text();
      console.log(`Body: ${text.substring(0, 100)}...`);
    }
  } catch (err) {
    console.log(`Error: ${err.message}`);
  }
}

testShipEngineRates();
